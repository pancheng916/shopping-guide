    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
